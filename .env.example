# Oracle BI Portal Credentials
# Copy this file to .env and fill in the real values
PORTAL_USERNAME=supyreports
PORTAL_COMPANY=indpt
PORTAL_PASSWORD=

# Gmail credentials for sending the daily report email
# GMAIL_USER:         your full Gmail / Google Workspace address
# GMAIL_APP_PASSWORD: 16-char App Password from Google Account → Security → App Passwords
# REPORT_RECIPIENT:   who receives the email (defaults to GMAIL_USER if blank)
GMAIL_USER=vaishnavi@supy.io
GMAIL_APP_PASSWORD=
REPORT_RECIPIENT=vaishnavi@supy.io
